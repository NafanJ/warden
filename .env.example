# Copy to .env on the host that runs warden. Never commit .env.

# --- LLM (agent brain) ---
# Which provider powers the investigating agent.
#   openai  → uses OPENAI_API_KEY + OPENAI_MODEL (cheap default: gpt-4o-mini)
#   claude  → uses ANTHROPIC_API_KEY (or Claude CLI auth) + WARDEN_MODEL
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
WARDEN_MODEL=claude-sonnet-4-6
# detect = sentinel only (no agent), dry-run = agent investigates but cannot act,
# active = Tier 1 autonomous + Tier 2 via approval
WARDEN_MODE=dry-run
WARDEN_MAX_BUDGET_USD=1.0

# --- Paths ---
WARDEN_STATE_DIR=state
# Keep reports under state/ so a deploy (rsync --delete excludes state/) can't wipe them.
WARDEN_INCIDENTS_DIR=state/incidents

# --- Monitored services (URLs as reachable from the warden host) ---
SONARR_URL=http://localhost:8989
SONARR_API_KEY=
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
TRANSMISSION_URL=http://localhost:9091/transmission/rpc
TRANSMISSION_USER=
TRANSMISSION_PASS=
# Tautulli (Plex stream activity + user stats) — optional
TAUTULLI_URL=http://localhost:8181
TAUTULLI_API_KEY=
# containers whose restart should ask first if people are streaming (comma-separated)
STREAM_CONTAINERS=plex
# Plex webhook (Plex Pass → Settings → Webhooks → http://localhost:8484/plex):
# throttle Transmission (alt-speed/turtle) while anyone is streaming, restore when idle.
PLEX_THROTTLE_DOWNLOADS=true
# Optional shared secret; if set, Plex URL must be .../plex?token=THIS
PLEX_WEBHOOK_TOKEN=

# --- Sentinel rules ---
DISK_PATHS=/,/mnt/Modi
DISK_THRESHOLD_PCT=92
# Optional: comma-separated public URLs to check for reachability (raises a
# tunnel_down incident if unreachable). Leave empty to disable — note a host
# often can't reach its own tunneled domains, so this can false-positive.
PUBLIC_URLS=
STALL_THRESHOLD_HOURS=4
STALL_MIN_AGE_HOURS=1
# remove a torrent from Transmission once it's 100% done and no *arr is still
# importing it (data is kept on disk). Set false to keep seeding.
REAP_COMPLETED_TORRENTS=true
# containers that are allowed to be down without raising an incident (comma-separated)
IGNORED_CONTAINERS=
# the only directory trees warden may ever delete within (comma-separated)
DELETE_ROOTS=/mnt/Modi/Kodi/downloads/

# --- Notifications ---
# log | discord | whatsapp   (discord is the easiest two-way setup — see DISCORD_SETUP.md)
NOTIFY_CHANNEL=log

# Discord (recommended): bot polls a channel for YES/NO replies — no public webhook.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_OWNER_ID=
# Optional: register native /status, /diagnose, /user-stats slash commands to this
# guild (server) id — they appear instantly. Leave blank to register globally (~1h).
DISCORD_GUILD_ID=

# WhatsApp (alternative): requires a Meta app + public webhook — see WHATSAPP_SETUP.md.
WA_TOKEN=
WA_PHONE_NUMBER_ID=
WA_TO=
WA_VERIFY_TOKEN=
WA_APP_SECRET=
