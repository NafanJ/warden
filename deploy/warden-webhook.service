[Unit]
Description=warden webhook — WhatsApp approvals + Plex playback events (127.0.0.1:8484)
After=network-online.target
Wants=network-online.target

[Service]
User=nathan
WorkingDirectory=/opt/warden
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/warden/.venv/bin/uvicorn warden.webhook.app:app --host 127.0.0.1 --port 8484
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
